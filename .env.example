# Edit model and other configs in app.config.json

# Chat (/ judge / rewrite / rerank) - NVIDIA NIM key
CHAT_API_KEY=

# Per-stage overrides (leave blank to reuse CHAT_API_KEY)
JUDGE_API_KEY=
REWRITE_API_KEY=
RERANK_API_KEY=

# Embeddings - Google Gemini API key (REQUIRED!)
EMBEDDING_API_KEY=

# Qdrant Cloud (private cluster endpoint + key)
QDRANT_URL=
QDRANT_API_KEY=