# MODEL CHOICES

# Chat LLM (OpenAI-compatible)

# --- OpenRouter ---
CHAT_API_KEY=
CHAT_BASE_URL=https://openrouter.ai/api/v1
CHAT_MODEL=google/gemma-4-26b-a4b-it:free

# --- Gemini ---
# CHAT_API_KEY=
# CHAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# CHAT_MODEL=gemini-3-flash-preview

# --- NVIDIA NIM ---
# CHAT_API_KEY=
# CHAT_BASE_URL=https://integrate.api.nvidia.com/v1
# CHAT_MODEL=meta/llama-3.1-8b-instruct

# Embeddings (optional override; leave blank to reuse CHAT_*)
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1
EMBEDDING_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2

# Corrective model overrides (optional; leave blank to reuse CHAT_*)
# Default uses OpenRouter free-tier models (Gemma 4 31B judge + Gemma 4 26B A4B helpers).
JUDGE_API_KEY=
JUDGE_BASE_URL=https://openrouter.ai/api/v1
JUDGE_MODEL=google/gemma-4-31b-it:free
JUDGE_MAX_TOKENS=300

REWRITE_API_KEY=
REWRITE_BASE_URL=https://openrouter.ai/api/v1
REWRITE_MODEL=google/gemma-4-26b-a4b-it:free
REWRITE_MAX_TOKENS=200

RERANK_API_KEY=
RERANK_BASE_URL=https://openrouter.ai/api/v1
RERANK_MODEL=google/gemma-4-26b-a4b-it:free
RERANK_MAX_TOKENS=400

# Qdrant Cloud
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=sst_genai_ass_3_rag_notebooklm

# RAG settings
CHUNK_SIZE=900
CHUNK_OVERLAP=150
MAX_CHUNKS=300
EMBEDDING_BATCH_SIZE=32
TOP_K=5
MAX_CONTEXT_CHARS=8000
MAX_CHUNK_CHARS=2000
MAX_OUTPUT_TOKENS=4000

# Corrective RAG behavior
CORRECTIVE_RAG_ENABLED=true
CORRECTIVE_RETRIES=1
CORRECTIVE_CONFIDENCE_THRESHOLD=0.55
CORRECTIVE_TOP_K=10
CORRECTIVE_REWRITE_COUNT=1
CORRECTIVE_RERANK=true
RERANK_TOP_N=8
RERANK_CHUNK_CHARS=600

# Cache
CACHE_TTL_MS=600000
CACHE_MAX=100

# Upload limits
MAX_FILE_MB=5

# Server
PORT=3000
